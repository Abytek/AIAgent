<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    />

    <title><%= agent.id %></title>

    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        body
        {
            background:
                radial-gradient(
                    circle at top,
                    rgba(99, 102, 241, 0.15),
                    transparent 40%
                ),
                #09090b;
        }

        .glass
        {
            background:
                rgba(24, 24, 27, 0.7);

            backdrop-filter:
                blur(12px);

            border:
                1px solid rgba(255, 255, 255, 0.08);
        }
    </style>
</head>

<body class="min-h-screen text-white">
    <div class="max-w-7xl mx-auto px-6 py-10">
        <!-- Header -->
        <div class="flex items-start justify-between gap-6">
            <div>
                <div
                    class="
                        inline-flex
                        items-center
                        gap-2
                        px-3
                        py-1
                        rounded-full
                        border
                        border-emerald-500/20
                        bg-emerald-500/10
                        text-emerald-400
                        text-sm
                        mb-4
                    "
                >
                    <div
                        class="
                            w-2
                            h-2
                            rounded-full
                            bg-emerald-400
                        "
                    ></div>

                    ONLINE
                </div>

                <h1
                    class="
                        text-5xl
                        font-bold
                        tracking-tight
                    "
                >
                    <%= agent.id %>
                </h1>

                <p
                    class="
                        text-zinc-400
                        mt-3
                        text-lg
                    "
                >
                    AI agent runtime monitor
                </p>
            </div>

            <a
                href="<%= agent.config?.root?.url || '/' %>"
                class="
                    px-5
                    py-3
                    rounded-2xl
                    bg-zinc-900
                    border
                    border-white/10
                    hover:bg-zinc-800
                    transition
                "
            >
                Go to root dashboard
            </a>
        </div>

        <!-- Grid -->
        <div
            class="
                mt-10
                grid
                grid-cols-1
                lg:grid-cols-3
                gap-6
            "
        >
            <!-- Runtime -->
            <div
                class="
                    lg:col-span-2
                    glass
                    rounded-3xl
                    p-6
                "
            >
                <div class="flex items-center justify-between">
                    <div>
                        <p
                            class="
                                text-xs
                                uppercase
                                tracking-[0.3em]
                                text-indigo-300
                            "
                        >
                            Runtime
                        </p>

                        <h2
                            class="
                                mt-3
                                text-2xl
                                font-semibold
                            "
                        >
                            Environment Information
                        </h2>
                    </div>

                    <div
                        class="
                            w-3
                            h-3
                            rounded-full
                            bg-emerald-400
                            shadow-[0_0_20px_rgba(52,211,153,0.8)]
                        "
                    ></div>
                </div>

                <div
                    class="
                        mt-8
                        grid
                        grid-cols-1
                        md:grid-cols-2
                        gap-5
                    "
                >
                    <div
                        class="
                            bg-black/40
                            border
                            border-white/5
                            rounded-2xl
                            p-5
                        "
                    >
                        <p class="text-zinc-500 text-sm">
                            Agent ID
                        </p>

                        <p
                            class="
                                mt-2
                                text-lg
                                font-medium
                                break-all
                            "
                        >
                            <%= agent.id %>
                        </p>
                    </div>

                    <div
                        class="
                            bg-black/40
                            border
                            border-white/5
                            rounded-2xl
                            p-5
                        "
                    >
                        <p class="text-zinc-500 text-sm">
                            Agent URL
                        </p>

                        <p
                            class="
                                mt-2
                                text-lg
                                font-medium
                                break-all
                            "
                        >
                            <%= agent.url %>
                        </p>
                    </div>

                    <div
                        class="
                            bg-black/40
                            border
                            border-white/5
                            rounded-2xl
                            p-5
                        "
                    >
                        <p class="text-zinc-500 text-sm">
                            Agent Brief
                        </p>

                        <p
                            class="
                                mt-2
                                text-lg
                                font-medium
                                break-all
                            "
                        >
                            <%= agent.brief %>
                        </p>
                    </div>

                    <div
                        class="
                            bg-black/40
                            border
                            border-white/5
                            rounded-2xl
                            p-5
                        "
                    >
                        <p class="text-zinc-500 text-sm">
                            Process ID
                        </p>

                        <p
                            class="
                                mt-2
                                text-lg
                                font-medium
                            "
                        >
                            <%= agent.processId %>
                        </p>
                    </div>

                    <div
                        class="
                            md:col-span-2
                            bg-black/40
                            border
                            border-white/5
                            rounded-2xl
                            p-5
                        "
                    >
                        <p class="text-zinc-500 text-sm">
                            Project Path
                        </p>

                        <p
                            class="
                                mt-2
                                text-lg
                                font-medium
                                break-all
                                text-zinc-200
                            "
                        >
                            <%= agent.path %>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Config -->
        <div
            class="
                mt-6
                glass
                rounded-3xl
                p-6
            "
        >
            <div class="flex items-center justify-between">
                <div>
                    <p
                        class="
                            text-xs
                            uppercase
                            tracking-[0.3em]
                            text-indigo-300
                        "
                    >
                        Configuration
                    </p>

                    <h2
                        class="
                            mt-3
                            text-2xl
                            font-semibold
                        "
                    >
                        Agent Config
                    </h2>
                </div>
            </div>

            <div
                class="
                    mt-6
                    bg-black/50
                    border
                    border-white/5
                    rounded-2xl
                    p-5
                    overflow-auto
                "
            >
                <pre
                    class="
                        text-sm
                        text-zinc-300
                        whitespace-pre-wrap
                        break-all
                    "
                ><%= JSON.stringify(agent.config, null, 4) %></pre>
            </div>
        </div>
    </div>
</body>
</html>