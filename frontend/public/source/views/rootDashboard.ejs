<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    />

    <title>Root Dashboard</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        body
        {
            background:
                radial-gradient(
                    circle at top,
                    rgba(99, 102, 241, 0.15),
                    transparent 40%
                ),
                #09090b;
        }
    </style>
</head>

<body class="bg-zinc-950 text-white min-h-screen">
    <div class="max-w-7xl mx-auto px-6 py-10">
        <!-- Header -->
        <div class="mb-12">
            <h1 class="text-5xl font-black tracking-tight">
                Root Dashboard
            </h1>

            <p class="text-zinc-400 mt-3 text-lg">
                Centralized management dashboard for AI agents.
            </p>
        </div>

        <!-- AI Agents -->
        <section class="space-y-8">
            <!-- Section Header -->
            <div>
                <h2 class="text-3xl font-bold">
                    AI Agents
                </h2>

                <p class="text-zinc-400 mt-2">
                    Register, update and manage AI agents.
                </p>
            </div>

            <!-- Register / Update Panel -->
            <div
                class="
                    bg-zinc-900/80
                    border
                    border-zinc-800
                    rounded-3xl
                    p-8
                    backdrop-blur
                "
            >
                <div class="flex items-start justify-between gap-6">
                    <div>
                        <h3 class="text-2xl font-bold">
                            Register / Update Agent
                        </h3>

                        <p class="text-zinc-400 mt-2">
                            Endpoint:
                            <span class="text-indigo-400 font-mono">
                                <script>
                                    document.write(
                                        window.location.origin +
                                        "/agentRegistry/set"
                                    );
                                </script>
                            </span>
                        </p>
                    </div>
                </div>

                <form
                    id="agentRegistryForm"
                    class="
                        mt-8
                        grid
                        grid-cols-1
                        md:grid-cols-2
                        gap-6
                    "
                >
                    <!-- Agent ID -->
                    <div class="space-y-2">
                        <label class="text-sm text-zinc-400">
                            Agent ID
                        </label>

                        <input
                            id="agentId"
                            type="text"
                            placeholder="AIAgent@simple"
                            class="
                                w-full
                                bg-zinc-950
                                border
                                border-zinc-800
                                rounded-xl
                                px-4
                                py-3
                                outline-none
                                focus:border-indigo-500
                                transition
                            "
                        />
                    </div>

                    <!-- Brief -->
                    <div class="space-y-2">
                        <label class="text-sm text-zinc-400">
                            Brief
                        </label>

                        <input
                            id="agentBrief"
                            type="text"
                            placeholder="A simple agent"
                            class="
                                w-full
                                bg-zinc-950
                                border
                                border-zinc-800
                                rounded-xl
                                px-4
                                py-3
                                outline-none
                                focus:border-indigo-500
                                transition
                            "
                        />
                    </div>

                    <!-- Tags -->
                    <div class="md:col-span-2 space-y-2">
                        <label class="text-sm text-zinc-400">
                            Tags
                        </label>

                        <input
                            id="agentTags"
                            type="text"
                            placeholder="assistant, coding, tools"
                            class="
                                w-full
                                bg-zinc-950
                                border
                                border-zinc-800
                                rounded-xl
                                px-4
                                py-3
                                outline-none
                                focus:border-indigo-500
                                transition
                            "
                        />
                    </div>

                    <!-- Buttons -->
                    <div
                        class="
                            md:col-span-2
                            flex
                            flex-wrap
                            gap-4
                            justify-end
                        "
                    >
                        <button
                            type="button"
                            id="clearButton"
                            class="
                                px-6
                                py-3
                                rounded-xl
                                bg-zinc-800
                                hover:bg-zinc-700
                                transition
                                font-semibold
                            "
                        >
                            Clear
                        </button>

                        <button
                            type="submit"
                            class="
                                px-8
                                py-3
                                rounded-xl
                                bg-indigo-500
                                hover:bg-indigo-400
                                transition
                                font-semibold
                            "
                        >
                            Save Agent Info
                        </button>
                    </div>
                </form>
            </div>

            <!-- Remove Agent Panel -->
            <div
                class="
                    bg-red-950/30
                    border
                    border-red-900/60
                    rounded-3xl
                    p-8
                    backdrop-blur
                "
            >
                <div class="flex items-start justify-between gap-6">
                    <div>
                        <h3 class="text-2xl font-bold text-red-300">
                            Remove Agent
                        </h3>

                        <p class="text-zinc-400 mt-2">
                            Only offline agents can be removed.
                        </p>

                        <p class="text-zinc-500 text-sm mt-3">
                            Endpoint:
                            <span class="text-red-400 font-mono">
                                <script>
                                    document.write(
                                        window.location.origin +
                                        "/agentRegistry/unset"
                                    );
                                </script>
                            </span>
                        </p>
                    </div>
                </div>

                <form
                    id="removeAgentForm"
                    class="
                        mt-8
                        flex
                        flex-col
                        md:flex-row
                        gap-4
                    "
                >
                    <input
                        id="removeAgentId"
                        type="text"
                        placeholder="Agent ID"
                        class="
                            flex-1
                            bg-zinc-950
                            border
                            border-red-900/60
                            rounded-xl
                            px-4
                            py-3
                            outline-none
                            focus:border-red-500
                            transition
                        "
                    />

                    <button
                        type="submit"
                        class="
                            px-8
                            py-3
                            rounded-xl
                            bg-red-500
                            hover:bg-red-400
                            transition
                            font-semibold
                        "
                    >
                        Remove Agent
                    </button>
                </form>
            </div>

            <!-- Agent List -->
            <div
                class="
                    grid
                    grid-cols-1
                    md:grid-cols-2
                    xl:grid-cols-3
                    gap-6
                "
            >
                <% for (const agent of agentSlots) { %>
                    <div
                        class="
                            relative
                            overflow-hidden
                            bg-zinc-900/80
                            border
                            border-zinc-800
                            rounded-3xl
                            p-6
                            backdrop-blur
                            group
                        "
                    >
                        <!-- Glow -->
                        <div
                            class="
                                absolute
                                -top-24
                                -right-24
                                w-48
                                h-48
                                rounded-full
                                blur-3xl
                                opacity-0
                                transition
                                duration-500
                                group-hover:opacity-100
                                <%= agent.isOnline
                                    ? 'bg-emerald-500/20'
                                    : 'bg-zinc-500/10'
                                %>
                            "
                        ></div>

                        <div class="relative z-10">
                            <!-- Header -->
                            <div class="flex items-start justify-between gap-4">
                                <div class="min-w-0">
                                    <h3
                                        class="
                                            text-xl
                                            font-bold
                                            break-all
                                        "
                                    >
                                        <%= agent.id %>
                                    </h3>

                                    <p
                                        class="
                                            text-zinc-400
                                            mt-2
                                            line-clamp-3
                                        "
                                    >
                                        <%= agent.brief %>
                                    </p>
                                </div>

                                <!-- Status -->
                                <div
                                    class="
                                        w-3
                                        h-3
                                        rounded-full
                                        border
                                        border-white/20
                                        shrink-0

                                        <%= agent.isOnline
                                            ? 'bg-emerald-400 shadow-[0_0_20px_rgba(74,222,128,0.8)]'
                                            : 'bg-zinc-500'
                                        %>
                                    "
                                ></div>
                            </div>

                            <!-- Tags -->
                            <div class="flex flex-wrap gap-2 mt-5">
                                <% for (const tag of (agent.tags || [])) { %>
                                    <div
                                        class="
                                            px-3
                                            py-1
                                            rounded-full
                                            bg-zinc-800
                                            text-sm
                                            text-zinc-300
                                        "
                                    >
                                        <%= tag %>
                                    </div>
                                <% } %>
                            </div>

                            <!-- Actions -->
                            <div class="flex gap-3 mt-8">
                                <!-- Edit -->
                                <button
                                    type="button"

                                    onclick='fillAgentForm(
                                        <%- JSON.stringify(agent.id) %>,
                                        <%- JSON.stringify(agent.brief || "") %>,
                                        <%- JSON.stringify(agent.tags || []) %>
                                    )'

                                    class="
                                        px-5
                                        py-3
                                        rounded-xl
                                        bg-zinc-800
                                        hover:bg-zinc-700
                                        transition
                                        font-semibold
                                    "
                                >
                                    Edit
                                </button>

                                <!-- Remove -->
                                <button
                                    type="button"

                                    onclick='fillRemoveForm(
                                        <%- JSON.stringify(agent.id) %>
                                    )'

                                    class="
                                        px-5
                                        py-3
                                        rounded-xl
                                        transition
                                        font-semibold

                                        <%= agent.isOnline
                                            ? 'bg-zinc-800 text-zinc-500 cursor-not-allowed'
                                            : 'bg-red-500 hover:bg-red-400'
                                        %>
                                    "

                                    <%= agent.isOnline
                                        ? 'disabled'
                                        : ''
                                    %>
                                >
                                    Remove
                                </button>

                                <!-- Open -->
                                <button
                                    type="button"

                                    <%= agent.isOnline
                                        ? `onclick="window.location.href='${agent.url}'"`
                                        : ''
                                    %>

                                    class="
                                        flex-1
                                        transition
                                        rounded-xl
                                        py-3
                                        font-semibold

                                        <%= agent.isOnline
                                            ? 'bg-indigo-500 hover:bg-indigo-400'
                                            : 'bg-zinc-700 opacity-60 cursor-not-allowed'
                                        %>
                                    "

                                    <%= agent.isOnline ? '' : 'disabled' %>
                                >
                                    Open
                                </button>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        </section>
    </div>

    <script>
        const form = document.getElementById(
            "agentRegistryForm"
        );

        const removeForm = document.getElementById(
            "removeAgentForm"
        );

        const clearButton = document.getElementById(
            "clearButton"
        );

        function fillAgentForm(id, brief, tags)
        {
            document.getElementById("agentId").value =
                id || "";

            document.getElementById("agentBrief").value =
                brief || "";

            document.getElementById("agentTags").value =
                (tags || []).join(", ");

            window.scrollTo({
                top: 0,
                behavior: "smooth"
            });
        }

        function fillRemoveForm(id)
        {
            document.getElementById(
                "removeAgentId"
            ).value = id || "";

            window.scrollTo({
                top: document.body.scrollHeight,
                behavior: "smooth"
            });
        }

        clearButton.addEventListener(
            "click",
            () =>
            {
                form.reset();
            }
        );

        form.addEventListener(
            "submit",
            async (event) =>
            {
                event.preventDefault();

                const id = document
                    .getElementById("agentId")
                    .value
                    .trim();

                const brief = document
                    .getElementById("agentBrief")
                    .value
                    .trim();

                const tags = document
                    .getElementById("agentTags")
                    .value
                    .split(",")
                    .map(v => v.trim())
                    .filter(v => v.length > 0);

                const body = {
                    id,
                    brief,
                    tags
                };

                try
                {
                    const response = await fetch(
                        window.location.origin +
                        "/agentRegistry/set",
                        {
                            method: "POST",

                            headers: {
                                "Content-Type":
                                    "application/json"
                            },

                            body: JSON.stringify(body)
                        }
                    );

                    if (!response.ok)
                    {
                        throw new Error(
                            "HTTP " + response.status
                        );
                    }

                    location.reload();
                }
                catch (error)
                {
                    console.error(error);

                    alert(
                        "Failed to save agent info."
                    );
                }
            }
        );

        removeForm.addEventListener(
            "submit",
            async (event) =>
            {
                event.preventDefault();

                const id = document
                    .getElementById("removeAgentId")
                    .value
                    .trim();

                if (!id)
                {
                    alert(
                        "Please enter an agent ID."
                    );

                    return;
                }

                const confirmed = confirm(
                    `Remove offline agent "${id}" ?`
                );

                if (!confirmed)
                {
                    return;
                }

                try
                {
                    const response = await fetch(
                        window.location.origin +
                        "/agentRegistry/unset/" + id,
                        {
                            method: "POST",
                        }
                    );

                    if (!response.ok)
                    {
                        throw new Error(
                            "HTTP " + response.status
                        );
                    }

                    location.reload();
                }
                catch (error)
                {
                    console.error(error);

                    alert(
                        "Failed to remove agent."
                    );
                }
            }
        );
    </script>
</body>
</html>