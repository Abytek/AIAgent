<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    />

    <title>Agents Dashboard</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        body
        {
            background:
                radial-gradient(
                    circle at top,
                    rgba(99, 102, 241, 0.15),
                    transparent 40%
                ),
                #09090b;
        }
    </style>
</head>

<body class="min-h-screen text-white">

    <div class="max-w-7xl mx-auto px-6 py-10">

        <!-- HEADER -->

        <div
            class="
                flex
                items-center
                justify-between
                mb-10
            "
        >
            <div>
                <h1
                    class="
                        text-5xl
                        font-black
                        tracking-tight
                    "
                >
                    AI Agents
                </h1>

                <p
                    class="
                        text-zinc-400
                        mt-3
                        text-lg
                    "
                >
                    Manage and monitor your running agents
                </p>
            </div>

            <div
                class="
                    bg-white/5
                    border
                    border-white/10
                    backdrop-blur-xl
                    rounded-2xl
                    px-5
                    py-3
                    shadow-2xl
                "
            >
                <p class="text-sm text-zinc-400">
                    Total Agents
                </p>

                <h2 class="text-3xl font-bold mt-1">
                    <%= agentList.length %>
                </h2>
            </div>
        </div>

        <!-- GRID -->

        <div
            class="
                grid
                grid-cols-1
                md:grid-cols-2
                xl:grid-cols-3
                gap-6
            "
        >

            <% agentList.forEach(agent => { %>

                <div
                    class="
                        group
                        relative
                        overflow-hidden
                        rounded-3xl
                        border
                        border-white/10
                        bg-white/5
                        backdrop-blur-xl
                        p-6
                        shadow-2xl
                        transition-all
                        duration-300
                        hover:scale-[1.02]
                        hover:border-indigo-500/40
                        hover:bg-white/[0.07]
                    "
                >

                    <!-- glow -->

                    <div
                        class="
                            absolute
                            -top-24
                            -right-24
                            w-48
                            h-48
                            bg-indigo-500/20
                            blur-3xl
                            rounded-full
                            opacity-0
                            transition
                            duration-500
                            group-hover:opacity-100
                        "
                    ></div>

                    <!-- content -->

                    <div class="relative z-10">

                        <div
                            class="
                                flex
                                items-start
                                justify-between
                                mb-6
                            "
                        >
                            <div>
                                <p
                                    class="
                                        text-xs
                                        uppercase
                                        tracking-[0.25em]
                                        text-indigo-300
                                        mb-3
                                    "
                                >
                                    Agent
                                </p>

                                <h2
                                    class="
                                        text-2xl
                                        font-bold
                                        break-all
                                    "
                                >
                                    <%= agent.id %>
                                </h2>
                            </div>

                            <div
                                class="
                                    w-3
                                    h-3
                                    rounded-full
                                    bg-emerald-400
                                    shadow-[0_0_20px_rgba(74,222,128,0.8)]
                                "
                            ></div>
                        </div>

                        <div
                            class="
                                bg-black/30
                                border
                                border-white/5
                                rounded-2xl
                                p-4
                            "
                        >
                            <p
                                class="
                                    text-xs
                                    uppercase
                                    tracking-widest
                                    text-zinc-500
                                    mb-2
                                "
                            >
                                Path
                            </p>

                            <p
                                class="
                                    text-zinc-300
                                    text-sm
                                    break-all
                                    leading-relaxed
                                "
                            >
                                <%= agent.path %>
                            </p>
                        </div>

                        <div
                            class="
                                flex
                                gap-3
                                mt-6
                            "
                        >
                            <button
                                onclick=" window.location.href = '<%= agent.url %>'"
                                class="
                                    flex-1
                                    bg-indigo-500
                                    hover:bg-indigo-400
                                    transition
                                    rounded-xl
                                    py-3
                                    font-semibold
                                "
                            >
                                Open
                            </button>

                            <button
                                class="
                                    flex-1
                                    bg-white/5
                                    hover:bg-white/10
                                    border
                                    border-white/10
                                    transition
                                    rounded-xl
                                    py-3
                                    font-semibold
                                "
                            >
                                Logs
                            </button>
                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

    </div>

</body>
</html>